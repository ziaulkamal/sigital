# .dockerignore — kecualikan artefak lokal dari build context
.git
.gitignore
node_modules
vendor
public/build
public/hot
public/storage
storage/app/certificates
storage/app/backups
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*
database/database.sqlite
.env
.env.*
!.env.docker
tests
phpunit.xml
screenshoot.png
README.md
PRD.md
rr
rr.exe
