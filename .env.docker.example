# .env.docker.example — environment kontainer (PostgreSQL + Redis + Octane/RoadRunner).
# Salin ke .env.docker lalu isi APP_KEY: `php artisan key:generate --show`
APP_NAME=SIGITAL
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=id

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Database - service "postgres" pada compose.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=sigital
DB_USERNAME=sigital
DB_PASSWORD=ubah-password-ini

# Sesi, cache, antrean -> Redis.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

# Penyimpanan & email.
FILESYSTEM_DISK=local
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@sigital.local"
MAIL_FROM_NAME="${APP_NAME}"

# SIGITAL.
SIGITAL_INSTANSI_KODE=DISKOMINFO
SIGITAL_INSTANSI_NAMA="Dinas Komunikasi dan Informatika"
SIGITAL_PDF_DISK=local
SIGITAL_PDFA=true
GHOSTSCRIPT_BIN=gs
SIGITAL_RETENSI_HARI=

# Octane + RoadRunner.
OCTANE_SERVER=roadrunner
OCTANE_HTTPS=false
